{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"strict": true,
		"esModuleInterop": true,
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"types": ["bun", "node"]
	},
	"include": ["index.ts", "src/**/*.ts"],
	"exclude": ["node_modules"]
}
